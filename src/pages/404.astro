---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/post.css";
import FeaturedPostHeader from "../components/featured-post-header/featured-post-header.astro";
import v1 from "../images/v1.jpg";
import v2 from "../images/v2.jpg";
import v3 from "../images/v3.jpg";
import v4 from "../images/v4.jpg";
import v5 from "../images/v5.jpg";
import v6 from "../images/v6.jpg";

const veganImages = [
  { src: v1, alt: "Vegan Roast Dinner 1" },
  { src: v2, alt: "Vegan Roast Dinner 2" },
  { src: v3, alt: "Vegan Roast Dinner 3" },
  { src: v4, alt: "Vegan Roast Dinner 4" },
  { src: v5, alt: "Vegan Roast Dinner 5" },
  { src: v6, alt: "Vegan Roast Dinner 6" },
];
---

<BaseLayout
  pageTitle="404 - Page Not Found"
  description="Welcome to Vegan Roast Dinners in London - Page not found"
>
  <FeaturedPostHeader
    imageSrc={veganImages[0].src.src}
    title="Welcome to Vegan Roast Dinners in London"
    imageAlt={veganImages[0].alt}
  />
  <div class="container">
    <div class="entry-content container">
      <p class="vegan-intro">
        Oops! Looks like you've wandered into our secret vegan section. Yes...it
        looks like hell.
      </p>

      <div class="vegan-gallery">
        {
          veganImages.map((image) => (
            <div class="vegan-image-container">
              <img
                src={image.src.src}
                alt={image.alt}
                loading="lazy"
                class="vegan-image"
              />
            </div>
          ))
        }
      </div>

      <div class="return-to-safety">
        <a href="/" class="safety-link">
          🥩 Return to Safety (Real Roast Dinners) 🥩
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
