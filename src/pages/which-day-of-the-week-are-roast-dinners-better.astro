---
import BaseLayout from "../layouts/BaseLayout.astro";
import { fetchGraphQL } from "../lib/api";
import type { Post } from "../types";
import Newsletter from "../components/newsletter/newsletter.astro";
import "../styles/post.css";

export const prerender = true;

import GET_ALL_POSTS from "../lib/queries/getAllPosts";

type DayStat = { name: string; total: number; count: number };

const dayStats: Record<number, DayStat> = {
  0: { name: "Sunday", total: 0, count: 0 },
  1: { name: "Monday", total: 0, count: 0 },
  2: { name: "Tuesday", total: 0, count: 0 },
  3: { name: "Wednesday", total: 0, count: 0 },
  4: { name: "Thursday", total: 0, count: 0 },
  5: { name: "Friday", total: 0, count: 0 },
  6: { name: "Saturday", total: 0, count: 0 },
};

let hasNextPage = true;
let endCursor: string | null = null;

while (hasNextPage) {
  const variables = endCursor ? { after: endCursor } : {};
  const { posts } = await fetchGraphQL(GET_ALL_POSTS, variables);

  posts.nodes.forEach((post: Post) => {
    const dateStr = post.date;
    const ratingStr = post.ratings?.nodes?.[0]?.name ?? "";
    const match = ratingStr.match(/[\d.]+/);
    const rating = match ? Number.parseFloat(match[0]) : null;

    if (!dateStr || rating === null || Number.isNaN(rating)) return;

    const d = new Date(dateStr);
    if (Number.isNaN(d.getTime())) return;

    const dayOfWeek = d.getDay();
    dayStats[dayOfWeek].total += rating;
    dayStats[dayOfWeek].count += 1;
  });

  hasNextPage = posts.pageInfo.hasNextPage;
  endCursor = posts.pageInfo.endCursor;
}

const dailyAverages = (Object.keys(dayStats) as unknown as number[]).map((day) => {
  const stats = dayStats[day];
  const average = stats.count > 0 ? +(stats.total / stats.count).toFixed(2) : null;
  return { day: stats.name, average, count: stats.count };
});

const sortedByAverage = [...dailyAverages].sort(
  (a, b) => (b.average ?? 0) - (a.average ?? 0)
);

const maxAverage = sortedByAverage[0]?.average ?? 10;
---

<BaseLayout
  pageTitle="Which Day Of The Week Are Roast Dinners Better?"
  description="An analysis of roast dinner ratings in London by day of the week. Find out which day serves up the best roast dinners."
>
  <div class="no-image-container">
    <section class="post-title">
      <h2>Which Day Of The Week Are Roast Dinners Better?</h2>
    </section>
  </div>
  <div class="container">
    <p>
      Everybody knows Sunday is the classic roast dinner day. But does Sunday actually
      serve up the best roast dinners in London? Let&#8217;s see what the data says.
    </p>

    <ul class="day-chart" aria-label="Average roast dinner ratings by day of the week">
      {
        sortedByAverage.map(({ day, average, count }) => (
          <li class="day-chart-row">
            <span class="day-name">{day}</span>
            <div class="bar-track" role="presentation">
              <div
                class="bar-fill"
                style={`width: ${average !== null && maxAverage > 0 ? Math.round((average / maxAverage) * 100) : 0}%`}
                aria-hidden="true"
              />
            </div>
            <span class="day-stats">
              {average !== null ? average.toFixed(2) : "N/A"}
              <span class="review-count">
                ({count} {count === 1 ? "review" : "reviews"})
              </span>
            </span>
          </li>
        ))
      }
    </ul>

    <p>
      Ratings are based on the date each review was published. Only posts with a
      valid numeric rating are counted.
    </p>

    <Newsletter />
  </div>
</BaseLayout>

<style>
  .day-chart {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin: 2rem 0;
    padding: 0;
  }

  .day-chart-row {
    display: grid;
    grid-template-columns: 110px 1fr auto;
    align-items: center;
    gap: 0.75rem;
    list-style: none;
  }

  .day-name {
    font-weight: bold;
    text-align: right;
    white-space: nowrap;
  }

  .bar-track {
    background: #e5e7eb;
    border-radius: 4px;
    height: 2rem;
    overflow: hidden;
    min-width: 60px;
  }

  .bar-fill {
    height: 100%;
    background: var(--roast-new-blue);
    border-radius: 4px;
    min-width: 2px;
    transition: width 0.3s ease;
  }

  .day-stats {
    font-size: 0.9rem;
    white-space: nowrap;
    min-width: 7rem;
  }

  .review-count {
    color: #666;
    font-size: 0.8rem;
  }

  @media (max-width: 480px) {
    .day-chart-row {
      grid-template-columns: 90px 1fr;
      grid-template-rows: auto auto;
    }

    .day-stats {
      grid-column: 1 / -1;
      text-align: center;
    }
  }
</style>
