---
type DropdownOption = {
  value: string;
  label: string;
};

interface Props {
  label: string;
  id: string;
  name: string;
  options: DropdownOption[];
  selectedValue?: string;
  formId?: string;
  formMethod?: "get" | "post";
  onChange?: string;
  defaultOptionLabel?: string;
  maxOptionLabelLength?: number;
  center?: boolean;
}

const {
  label,
  id,
  name,
  options,
  selectedValue = "",
  formId,
  formMethod = "get",
  onChange = "this.form.submit()",
  defaultOptionLabel,
  maxOptionLabelLength,
  center = false,
} = Astro.props;

const getDisplayLabel = (labelToFormat: string) => {
  if (!maxOptionLabelLength || labelToFormat.length <= maxOptionLabelLength) {
    return labelToFormat;
  }

  return `${labelToFormat.slice(0, maxOptionLabelLength - 1).trimEnd()}…`;
};
---

<label
  for={id}
  style={center ? "display: block; text-align: center;" : undefined}
  >{label}</label
>
<form
  id={formId}
  method={formMethod}
  style={center ? "display: flex; justify-content: center;" : undefined}
>
  <select
    id={id}
    name={name}
    value={selectedValue}
    onchange={onChange}
    style="min-width: 200px;"
  >
    {defaultOptionLabel && <option value="">{defaultOptionLabel}</option>}
    {
      options.map((option) => (
        <option
          value={option.value}
          selected={selectedValue === option.value}
          title={option.label}
        >
          {getDisplayLabel(option.label)}
        </option>
      ))
    }
  </select>
</form>
