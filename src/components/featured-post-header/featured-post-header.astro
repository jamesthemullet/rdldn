---
interface Props {
  imageSrc: string;
  title: string;
  imageAlt?: string;
}

const { imageSrc, title, imageAlt = title }: Props = Astro.props;
---

<div class="image-container">
  <img
    src={imageSrc}
    alt={imageAlt}
    width={1200}
    height={800}
    class="featured-image"
    loading="eager"
  />
  <slot name="overlay" />
  <div class="copyright-overlay">
    © {new Date().getFullYear()} Roast Dinners in London. All rights reserved.
  </div>
</div>
<section class="post-title">
  <h2>{title}</h2>
  <slot name="meta" />
</section>
